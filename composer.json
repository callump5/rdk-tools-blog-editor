{
    "name": "rdk-tools/blog-editor",
    "description": "editor component",
    "autoload": {
        "psr-4": {
            "RdkTools\\BlogEditor\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "RdkTools\\BlogEditor\\BlogEditorServiceProvider"
            ]
        }
    },
    "require": {
        "livewire/livewire": "4.2.4",
        "ezyang/htmlpurifier": "4.19.0"
    },
    "scripts": {
        "post-autoload-dump": [
            "@php artisan vendor:publish --tag=blog-editor-assets --force"
        ]
    }
}
